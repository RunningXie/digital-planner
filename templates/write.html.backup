<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>写日记 - Dear Diary</title>
    <link rel="stylesheet" href="/static/css/style.css">
    <style>
        .write-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 2rem;
        }
        
        .write-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }
        
        .title-input {
            flex: 1;
            font-size: 1.5rem;
            font-weight: bold;
            border: none;
            background: transparent;
            color: var(--warm-primary-dark);
            padding: 0.5rem;
            border-bottom: 2px solid transparent;
        }
        
        .title-input:focus {
            outline: none;
            border-bottom-color: var(--warm-primary);
        }
        
        .write-content {
            display: grid;
            grid-template-columns: 1fr 350px;
            gap: 2rem;
        }
        
        @media (max-width: 900px) {
            .write-content {
                grid-template-columns: 1fr;
            }
        }
        
        .editor-section {
            background: var(--warm-card);
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: var(--shadow-soft);
        }
        
        .editor-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--warm-border);
        }
        
        .diary-textarea {
            width: 100%;
            min-height: 400px;
            border: none;
            background: var(--warm-bg);
            padding: 1rem;
            border-radius: 12px;
            font-size: 1rem;
            font-family: 'Georgia', serif;
            line-height: 1.8;
            resize: vertical;
        }
        
        .diary-textarea:focus {
            outline: none;
        }
        
        .helper-section {
            position: sticky;
            top: 100px;
        }
        
        .phrase-search-box {
            background: var(--warm-card);
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: var(--shadow-soft);
            margin-bottom: 1.5rem;
        }
        
        .phrase-search-box h3 {
            color: var(--warm-primary-dark);
            margin-bottom: 1rem;
            font-size: 1.1rem;
        }
        
        .search-input-group {
            display: flex;
            gap: 0.5rem;
        }
        
        .search-input-group input {
            flex: 1;
            padding: 0.75rem;
            border: 2px solid var(--warm-border);
            border-radius: 8px;
            font-size: 0.9rem;
        }
        
        .search-input-group button {
            padding: 0.75rem 1rem;
            background: var(--warm-primary);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }
        
        .phrase-results {
            margin-top: 1rem;
        }
        
        .phrase-result-item {
            background: var(--warm-bg);
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 0.5rem;
        }
        
        .phrase-result-item strong {
            color: var(--warm-primary-dark);
        }
        
        .phrase-result-item ul {
            margin-left: 1.5rem;
            color: var(--warm-text-light);
        }
        
        .submit-section {
            margin-top: 1.5rem;
            display: flex;
            gap: 1rem;
        }
        
        .submit-section .btn {
            flex: 1;
        }
        
        .corrections-section {
            background: var(--warm-card);
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: var(--shadow-soft);
            margin-top: 2rem;
        }
        
        .correction-card {
            background: linear-gradient(135deg, #f8f4ef 0%, #f0ebe3 100%);
            border-radius: 12px;
            padding: 1.25rem;
            margin-bottom: 1rem;
            border-left: 4px solid var(--warm-primary);
        }
        
        .correction-original {
            color: #c97b7b;
            text-decoration: line-through;
            margin-bottom: 0.5rem;
        }
        
        .correction-corrected {
            color: #7a9e7e;
            font-weight: bold;
            margin-bottom: 0.5rem;
        }
        
        .correction-explanation {
            color: var(--warm-text-light);
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }
        
        .suggestion-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        
        .suggestion-tag {
            background: var(--warm-secondary);
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.8rem;
            color: var(--warm-text);
        }
        
        .optimized-content {
            background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
            border-radius: 12px;
            padding: 1.5rem;
            margin-top: 1.5rem;
        }
        
        .optimized-content h4 {
            color: #2e7d32;
            margin-bottom: 1rem;
        }
        
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        
        .loading-content {
            background: white;
            padding: 2rem;
            border-radius: 16px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="write-container">
        <div class="write-header">
            <h1 style="color: var(--warm-primary-dark);">✍️ 写日记</h1>
        </div>
        
        <div class="write-content">
            <div class="editor-section">
                <div class="editor-toolbar">
                    <span style="color: var(--warm-text-light); font-size: 0.9rem;">用英文写下今天的故事...</span>
                </div>
                
                <div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
                    <input type="date" id="diaryDate" class="form-input" style="flex: 0 0 150px; padding: 0.5rem;">
                    <input type="text" id="diaryTitle" class="title-input" placeholder="标题（可选）..." style="flex: 1; margin-bottom: 0;">
                </div>
                
                <textarea id="diaryContent" class="diary-textarea" placeholder="Start writing your diary in English..."></textarea>
                
                <div class="submit-section">
                    <button onclick="saveDiary()" class="btn btn-primary">保存并批改</button>
                    <button onclick="clearEditor()" class="btn btn-secondary">清空</button>
                </div>
            </div>
            
            <div class="helper-section">
                <div class="phrase-search-box">
                    <h3>🔍 短语搜索</h3>
                    <p style="color: var(--warm-text-light); font-size: 0.85rem; margin-bottom: 1rem;">
                        不知道如何表达？输入中文或英文来搜索地道的表达方式
                    </p>
                    <div class="search-input-group">
                        <input type="text" id="phraseInput" placeholder="输入要搜索的短语..." onkeypress="handlePhraseKeypress(event)">
                        <button onclick="searchPhraseExpression()">搜索</button>
                    </div>
                    <div id="phraseResults" class="phrase-results"></div>
                </div>
                
                <div class="card" style="background: linear-gradient(135deg, #fef9e7 0%, #fdebd0 100%);">
                    <h3 style="color: var(--warm-primary-dark); margin-bottom: 0.5rem;">💡 写作小贴士</h3>
                    <ul style="color: var(--warm-text-light); font-size: 0.9rem; margin-left: 1.5rem;">
                        <li>用英文写日记，记录生活的点滴</li>
                        <li>AI会帮你批改语法和用词</li>
                        <li>查看优化后的版本，学习更地道的表达</li>
                    </ul>
                </div>
            </div>
        </div>
        
        <div id="correctionsSection" class="corrections-section" style="display: none;">
            <h3 style="color: var(--warm-primary-dark); margin-bottom: 1rem;">📝 批改结果</h3>
            <div id="correctionsList"></div>
            <div id="optimizedContent" class="optimized-content" style="display: none;">
                <h4>✨ 优化后的版本</h4>
                <p id="optimizedText"></p>
            </div>
        </div>
    </div>
    
    <div id="loadingOverlay" class="loading-overlay" style="display: none;">
        <div class="loading-content">
            <div class="spinner"></div>
            <p style="margin-top: 1rem; color: var(--warm-text);">AI正在批改中，请稍候...</p>
            <p style="margin-top: 0.5rem; color: var(--warm-text-light); font-size: 0.85rem;">通常需要 30-60 秒</p>
        </div>
    </div>

    <script src="/static/js/app.js"></script>
    <script>
        // 检查登录状态
        if (!isLoggedIn()) {
            window.location.href = '/login';
        }
        
        // 搜索短语
        function handlePhraseKeypress(event) {
            if (event.key === 'Enter') {
                searchPhraseExpression();
            }
        }
        
        async function searchPhraseExpression() {
            const phrase = document.getElementById('phraseInput').value.trim();
            if (!phrase) return;
            
            const resultsDiv = document.getElementById('phraseResults');
            resultsDiv.innerHTML = '<div class="loading"><div class="spinner"></div><p style="margin-top:0.5rem;color:var(--warm-text-light);font-size:0.85rem;">搜索中，约需10-30秒...</p></div>';
            
            try {
                const result = await searchPhrase(phrase);
                displayPhraseResults(result);
            } catch (error) {
                resultsDiv.innerHTML = '<p style="color: var(--warm-error);">搜索失败，请重试</p>';
            }
        }
        
        function displayPhraseResults(result) {
            const resultsDiv = document.getElementById('phraseResults');
            let html = '';
            
            if (result.translations && result.translations.length > 0) {
                html += `<div class="phrase-result-item">
                    <strong>翻译：</strong>
                    <ul>${result.translations.map(t => `<li>${t}</li>`).join('')}</ul>
                </div>`;
            }
            
            if (result.examples && result.examples.length > 0) {
                html += `<div class="phrase-result-item">
                    <strong>例句：</strong>
                    <ul>${result.examples.map(e => `<li>${e}</li>`).join('')}</ul>
                </div>`;
            }
            
            if (result.alternatives && result.alternatives.length > 0) {
                html += `<div class="phrase-result-item">
                    <strong>其他表达：</strong>
                    <ul>${result.alternatives.map(a => `<li>${a}</li>`).join('')}</ul>
                </div>`;
            }
            
            if (!html) {
                html = '<p style="color: var(--warm-text-light);">没有找到相关结果</p>';
            }
            
            resultsDiv.innerHTML = html;
        }
        
        // 保存日记 — 防重复点击
        let _isSaving = false;
        async function saveDiary() {
            // 防止重复点击
            if (_isSaving) return;
            
            const title = document.getElementById('diaryTitle').value.trim();
            const content = document.getElementById('diaryContent').value.trim();
            const diaryDate = document.getElementById('diaryDate').value;
            
            if (!content) {
                showMessage('请输入日记内容', 'error');
                return;
            }
            
            _isSaving = true;
            const saveBtn = document.querySelector('.submit-section .btn-primary');
            if (saveBtn) saveBtn.disabled = true;
            
            const loadingOverlay = document.getElementById('loadingOverlay');
            loadingOverlay.style.display = 'flex';
            
            try {
                const diary = await createDiary(title, content, diaryDate);
                displayCorrections(diary);
                showMessage('日记已保存并批改完成！', 'success');
            } catch (error) {
                showMessage('保存失败：' + error.message, 'error');
            } finally {
                _isSaving = false;
                loadingOverlay.style.display = 'none';
                if (saveBtn) saveBtn.disabled = false;
            }
        }
        
        // 显示批改结果
        function displayCorrections(diary) {
            const section = document.getElementById('correctionsSection');
            const listDiv = document.getElementById('correctionsList');
            const optimizedDiv = document.getElementById('optimizedContent');
            const optimizedText = document.getElementById('optimizedText');
            
            section.style.display = 'block';
            listDiv.innerHTML = '';
            
            // 滚动到批改区域
            section.scrollIntoView({ behavior: 'smooth' });
            
            // 处理 AI 批改失败的情况
            if (diary.error) {
                listDiv.innerHTML = `<div class="correction-card" style="border-left-color: #e74c3c;">
                    <div style="color: #e74c3c; font-weight: bold;">⚠️ AI 批改出错</div>
                    <div style="color: var(--warm-text-light); margin-top: 0.5rem;">${diary.error}</div>
                    <div style="color: var(--warm-text-light); margin-top: 0.5rem;">请稍后重试，或检查 AI 服务配置。</div>
                </div>`;
                optimizedDiv.style.display = 'none';
                return;
            }
            
            if (diary.corrections && diary.corrections.length > 0) {
                // 分离有错误和无错误的句子
                const hasErrors = diary.corrections.filter(c => c.explanation !== 'No errors found.');
                const noErrors = diary.corrections.filter(c => c.explanation === 'No errors found.');
                
                if (hasErrors.length > 0) {
                    hasErrors.forEach((correction, index) => {
                        const card = document.createElement('div');
                        card.className = 'correction-card';
                        card.innerHTML = `
                            <div class="correction-original">原文：${correction.original}</div>
                            <div class="correction-corrected">✓ ${correction.corrected}</div>
                            <div class="correction-explanation">📖 ${correction.explanation || '无解释'}</div>
                            ${correction.suggestions && correction.suggestions.length > 0 ? `
                                <div class="suggestion-tags">
                                    ${correction.suggestions.map(s => `<span class="suggestion-tag">${s}</span>`).join('')}
                                </div>
                            ` : ''}
                        `;
                        listDiv.appendChild(card);
                    });
                }
                
                if (noErrors.length > 0) {
                    const summary = document.createElement('div');
                    summary.style.cssText = 'color: #7a9e7e; font-size: 0.9rem; margin-top: 0.5rem;';
                    summary.textContent = `✅ ${noErrors.length} 个句子没有错误`;
                    if (hasErrors.length === 0) {
                        listDiv.innerHTML = '<p style="color: #7a9e7e; font-weight: bold;">🎉 太棒了！你的日记没有语法错误！</p>';
                    }
                    listDiv.appendChild(summary);
                }
            } else {
                listDiv.innerHTML = '<p style="color: var(--warm-text-light);">⚠️ AI 未返回批改结果，请重试。</p>';
            }
            
            if (diary.optimized_content) {
                optimizedDiv.style.display = 'block';
                optimizedText.textContent = diary.optimized_content;
            } else {
                optimizedDiv.style.display = 'none';
            }
        }
        
        // 清空编辑器
        function clearEditor() {
            document.getElementById('diaryTitle').value = '';
            document.getElementById('diaryContent').value = '';
            document.getElementById('correctionsSection').style.display = 'none';
        }
    </script>
</body>
</html>